<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_tonal"
            android:text="◀"
            android:textColor="@color/md_primary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnForward"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_tonal"
            android:text="▶"
            android:textColor="@color/md_primary"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etPath"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip"
            android:hint="/storage/emulated/0"
            android:imeOptions="actionGo"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:singleLine="true"
            android:textColor="@color/md_text_primary"
            android:textColorHint="@color/md_text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSort"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chip"
            android:text="序"
            android:textColor="@color/md_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGo"
            android:layout_width="50dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_primary"
            android:text="GO"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGrant"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_tonal"
            android:text="✓"
            android:textColor="@color/md_success"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ListView
        android:id="@+id/lvSuggest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_card"
        android:divider="@color/md_outline"
        android:dividerHeight="1dp"
        android:elevation="2dp"
        android:scrollbars="none"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="4dp">

        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:cacheColorHint="@android:color/transparent"
            android:divider="@color/md_outline"
            android:dividerHeight="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:padding="10dp">

        <Button
            android:id="@+id/btnNewFolder"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_tonal"
            android:text="新建"
            android:textColor="@color/md_success"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnPaste"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_tonal"
            android:text="粘贴"
            android:textColor="@color/md_text_primary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDetail"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_tonal"
            android:text="详细:关"
            android:textColor="@color/md_text_primary"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
